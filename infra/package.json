{
  "name": "tollroad-infra",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "tollroad": "bin/tollroad.ts"
  },
  "scripts": {
    "build": "tsc",
    "synth": "cdk synth",
    "deploy": "node scripts/deploy.mjs",
    "deploy:check": "node scripts/deploy.mjs --check",
    "deploy:raw": "cdk deploy",
    "destroy": "cdk destroy",
    "migrate": "node scripts/migrate-dsql.mjs",
    "seed:assets": "node scripts/gen-demo-assets.mjs",
    "seed:demo": "node scripts/seed-demo.mjs",
    "seed:reset": "node scripts/seed-demo.mjs --reset",
    "seed:catalog-covers": "node scripts/gen-catalog-covers.mjs"
  },
  "devDependencies": {
    "@types/node": "^20",
    "aws-cdk": "^2.160.0",
    "esbuild": "^0.28.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/dsql-signer": "^3.1065.0",
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.3.0",
    "pg": "^8.13.0",
    "source-map-support": "^0.5.21"
  }
}
