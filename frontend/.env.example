# Copy to .env.local for local dev. The artist sign-up route (/api/artists)
# connects to Aurora DSQL using the ambient AWS credential chain (your AWS
# profile locally; the tollroad-vercel IAM user in production).

# DSQL cluster endpoint — from the CDK `DsqlEndpoint` output.
TOLLROAD_DSQL_ENDPOINT=cft3bvnxxyf7wdemb6vksy6ouy.dsql.us-east-1.on.aws
TOLLROAD_DSQL_REGION=us-east-1

# --- Auth (sonar-style email OTP) ---
# Session JWT signing secret — ≥32 chars of entropy. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
TOLLROAD_SESSION_SECRET=
# Verified SES sender for OTP emails, e.g. "TollRoad <login@yourdomain>".
# When unset, codes are logged to the server console (fine for local dev).
TOLLROAD_SES_SENDER=

# --- Media encryption (at-rest audio) ---
# Audio is stored encrypted (AES-256-GCM); /api/stream decrypts on the fly only
# AFTER a play has been billed. 32-byte key, base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Then encrypt the demo audio:  node infra/scripts/encrypt-media.mjs
# When unset, the stream route falls back to the plaintext files in /public
# (the billing gate still applies) so the demo runs without a key.
TOLLROAD_MEDIA_KEY=

# --- Wallet top-ups (Stripe) ---
# Listeners prepay a balance the meter draws against. Top-ups run on Stripe:
# ACH bank debit (us_bank_account, no fee passed on) or card (the 2.9% + 30¢
# processing fee is added to the listener's charge). When STRIPE_SECRET_KEY is
# unset the top-up sheet offers a "demo" credit so the funds→play loop is
# testable locally without Stripe.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: verifies Stripe webhook signatures at /api/billing/webhook.
STRIPE_WEBHOOK_SECRET=

# --- Artist-uploaded images (cover art + avatars) ---
# Public CloudFront base for the images bucket — from the CDK `ImagesCdnDomain`
# output (set to https://<that-domain>). CoverImage resolves bucket-relative
# keys (e.g. track-covers/<id>.jpg) against this. When unset, only the legacy
# /covers/*.svg static catalog art renders; uploaded images won't resolve.
NEXT_PUBLIC_IMAGES_BASE=
