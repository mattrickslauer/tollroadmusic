# Copy to .env.local for local dev. The artist sign-up route (/api/artists)
# connects to Aurora DSQL using the ambient AWS credential chain (your AWS
# profile locally; the tollroad-vercel IAM user in production).

# DSQL cluster endpoint — from the CDK `DsqlEndpoint` output.
TOLLROAD_DSQL_ENDPOINT=cft3bvnxxyf7wdemb6vksy6ouy.dsql.us-east-1.on.aws
TOLLROAD_DSQL_REGION=us-east-1

# --- Auth (sonar-style email OTP) ---
# Session JWT signing secret — ≥32 chars of entropy. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
TOLLROAD_SESSION_SECRET=
# Verified SES sender for OTP emails, e.g. "TollRoad <login@yourdomain>".
# When unset, codes are logged to the server console (fine for local dev).
TOLLROAD_SES_SENDER=
