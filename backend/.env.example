# Backend service env for local dev. Copy to backend/.env (gitignored); the
# `npm run dev` script loads it via Node's --env-file-if-exists. In production
# these come from the Lambda's environment (see infra/lib/tollroad-stack.ts).
#
# DSQL auth uses the ambient AWS credential chain (your AWS profile locally),
# so also have AWS creds available, e.g. `export AWS_PROFILE=...`.

# --- Required for DB-backed features (catalog, wallet, library, auth) ---
# Aurora DSQL cluster endpoint — from the CDK `DsqlEndpoint` output.
TOLLROAD_DSQL_ENDPOINT=
TOLLROAD_DSQL_REGION=us-east-1

# --- Required for sign-in (email OTP -> session JWT) ---
# >=32 chars of entropy. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
TOLLROAD_SESSION_SECRET=

# --- Optional: all have graceful local fallbacks ---
# Verified SES sender for OTP emails. When unset, the code is logged to the
# backend console instead of emailed (fine for local dev).
TOLLROAD_SES_SENDER=
# Stripe — when unset, the top-up sheet offers an instant demo credit so the
# fund -> play loop works without Stripe.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# CloudFront signed-URL streaming. When unset, streaming falls back to a local
# proxy that serves the seeded audio from frontend/public (billing still gates).
TOLLROAD_CDN_DOMAIN=
TOLLROAD_CF_KEY_PAIR_ID=
TOLLROAD_CF_PRIVATE_KEY=
# AES-256-GCM key (base64, 32 bytes) for at-rest audio. When unset, plaintext
# files in frontend/public are served. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOLLROAD_MEDIA_KEY=
# Override where proxy-mode audio is read from (default: ../frontend/public).
TOLLROAD_MEDIA_ROOT=
# CORS allow-list for the public API (not needed for the same-origin proxy).
TOLLROAD_ALLOWED_ORIGINS=
# Local server port (default 8787).
PORT=8787
